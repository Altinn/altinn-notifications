# Version Control
.git/
.gitattributes
.gitignore

# GitHub & CI/CD
.github/

# IDE & Editor
**/*.csproj.user
**/*.dcproj
**/launchSettings.json
*.suo
*.user
.idea/
.vs/
.vscode/

# Build Outputs
**/bin/
**/obj/
**/out/
**/publish/

