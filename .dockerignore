# -----------------------------------------------------------------------------
# Version Control
# -----------------------------------------------------------------------------
.git/
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# GitHub & CI/CD
# -----------------------------------------------------------------------------
.github/

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.vs/
.vscode/
.idea/
*.user
*.suo
**/*.csproj.user

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
**/bin/
**/obj/
**/out/
**/publish/

# -----------------------------------------------------------------------------
# Tests
# -----------------------------------------------------------------------------
**/test/
**/tests/
**/*Tests/
**/*IntegrationTests/

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
tools/
components/api/src/Tools/

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
docs/
*.md

# -----------------------------------------------------------------------------
# Configuration (not needed in container)
# -----------------------------------------------------------------------------
.editorconfig
renovate.json
stylecop.json
LICENSE

# -----------------------------------------------------------------------------
# NuGet
# -----------------------------------------------------------------------------
**/packages/
**/*.nupkg
**/nuget.config

# -----------------------------------------------------------------------------
# Temporary & Log Files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.cache

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Docker (prevent recursive context)
# -----------------------------------------------------------------------------
**/.dockerignore
docker-compose*.yml
