# Path to config.json
# Linux/macOS:
CONFIG_PATH=./config.json

# Windows: use double backslash, e.g:
# CONFIG_PATH="C:\\dev\\sb-emulator\\config.json"

# EULA must be accepted for both emulator and MSSQL
ACCEPT_EULA=Y

# Strong SA password (at least 8 chars, complexity required)
MSSQL_SA_PASSWORD=Str0ng!Passw0rd_ChangeMe

# Compose variables
EMULATOR_HTTP_PORT=5300
SQL_WAIT_INTERVAL=15