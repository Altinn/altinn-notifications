meta {
  name: Validation - non-Azure sasUrl host
  type: http
  seq: 7
}

post {
  url: {{host}}/notifications/api/v1/future/orders/composed-email
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "{{senders_reference_guid}}",
    "requestedSendTime": "{{process.env.TESTDATA_REQUESTED_SEND_TIME}}",
    "recipient": {
      "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
      "emailSettings": {
        "subject": "(TEST) Should fail - non-Azure sasUrl host",
        "body": "(TEST) This should be rejected",
        "contentType": "Plain",
        "sendingTimePolicy": "Anytime",
        "attachments": [
          {
            "filename": "document.pdf",
            "mimeType": "application/pdf",
            "sasUrl": "https://attacker.example.com/container/file.pdf?se=2099-01-01T00%3A00%3A00Z&sp=r&sr=b&sig=fake"
          }
        ]
      }
    }
  }
}

docs {
  Validation: the sasUrl host is not within Azure Blob Storage (*.blob.core.windows.net).
  Only Azure Blob Storage hosts are permitted to prevent SSRF attacks.
  The request must be rejected with 400 Bad Request.

  Expected: 400 Bad Request with a validation error referencing sasUrl host.
}
