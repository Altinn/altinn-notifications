meta {
  name: Happy path - single PDF file reference
  type: http
  seq: 1
}

post {
  url: {{host}}/notifications/api/v1/future/orders/composed-email
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "{{senders_reference_guid}}",
    "requestedSendTime": "{{process.env.TESTDATA_REQUESTED_SEND_TIME}}",
    "recipient": {
      "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
      "emailSettings": {
        "subject": "(TEST) Composed email - single PDF",
        "body": "(TEST) Composed email with a single PDF file reference (Env.: {{Environment}} - Ref: {{random_idempotency_id}})",
        "contentType": "Plain",
        "sendingTimePolicy": "Anytime",
        "attachments": [
          {
            "filename": "test-document.pdf",
            "mimeType": "application/pdf",
            "sasUrl": "{{process.env.TESTDATA_ATTACHMENT_SAS_URL}}"
          }
        ]
      }
    }
  }
}

tests {
  test("should return 201 status code", function() {
    expect(res.getStatus()).to.equal(201);
  });
}

docs {
  Happy path: registers a composed email order with a single PDF file reference.

  Required environment variables:
  - TESTDATA_MY_EMAIL: Recipient email address
  - TESTDATA_ATTACHMENT_SAS_URL: Valid SAS URL to a PDF blob with 'se' expiry at least 15 minutes after requestedSendTime
  - TESTDATA_REQUESTED_SEND_TIME: ISO 8601 UTC datetime (e.g. 2026-06-23T16:00:00Z)

  Expected: 201 Created with order chain details in the response body.
  Response body: { "notificationOrderId": "<guid>", "notification": { "shipmentId": "<guid>", "sendersReference": "...", "reminders": null } }
}
