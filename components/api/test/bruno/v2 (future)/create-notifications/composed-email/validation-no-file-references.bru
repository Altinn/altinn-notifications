meta {
  name: Validation - no file references
  type: http
  seq: 5
}

post {
  url: {{host}}/notifications/api/v1/future/orders/composed-email
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "{{senders_reference_guid}}",
    "requestedSendTime": "{{process.env.TESTDATA_REQUESTED_SEND_TIME}}",
    "recipient": {
      "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
      "emailSettings": {
        "subject": "(TEST) Should fail - no file references",
        "body": "(TEST) This should be rejected",
        "contentType": "Plain",
        "sendingTimePolicy": "Anytime",
        "attachments": []
      }
    }
  }
}

docs {
  Validation: the attachments array is empty. At least one file reference is required.
  The request must be rejected with 400 Bad Request.

  Expected: 400 Bad Request with a validation error referencing attachments.
}
