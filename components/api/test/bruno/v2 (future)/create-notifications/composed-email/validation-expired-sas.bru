meta {
  name: Validation - expired SAS URL
  type: http
  seq: 3
}

post {
  url: {{host}}/notifications/api/v1/future/orders/composed-email
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "{{senders_reference_guid}}",
    "requestedSendTime": "{{process.env.TESTDATA_REQUESTED_SEND_TIME}}",
    "recipient": {
      "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
      "emailSettings": {
        "subject": "(TEST) Should fail - expired SAS",
        "body": "(TEST) This should be rejected",
        "contentType": "Plain",
        "sendingTimePolicy": "Anytime",
        "attachments": [
          {
            "filename": "document.pdf",
            "mimeType": "application/pdf",
            "sasUrl": "https://example.blob.core.windows.net/container/file.pdf?se=2020-01-01T00%3A00%3A00Z&sp=r&sr=b&sig=fake"
          }
        ]
      }
    }
  }
}

docs {
  Validation: the SAS URL 'se' expiry (2020-01-01) is in the past and well before
  requestedSendTime + 15 minutes. The request must be rejected with 400 Bad Request.

  Expected: 400 Bad Request with a validation error referencing the sasUrl expiry.
}
