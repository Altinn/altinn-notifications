meta {
  name: Validation - unsupported MIME type
  type: http
  seq: 4
}

post {
  url: {{host}}/notifications/api/v1/future/orders/email-with-attachments
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "{{senders_reference_guid}}",
    "requestedSendTime": "{{process.env.TESTDATA_REQUESTED_SEND_TIME}}",
    "recipient": {
      "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
      "emailSettings": {
        "subject": "(TEST) Should fail - unsupported MIME type",
        "body": "(TEST) This should be rejected",
        "contentType": "Plain",
        "sendingTimePolicy": "Anytime",
        "attachments": [
          {
            "filename": "script.exe",
            "mimeType": "application/x-msdownload",
            "sasUrl": "{{process.env.TESTDATA_ATTACHMENT_SAS_URL}}"
          }
        ]
      }
    }
  }
}

docs {
  Validation: 'application/x-msdownload' (.exe) is not in the ACS-supported MIME type list.
  The request must be rejected with 400 Bad Request.

  Expected: 400 Bad Request with a validation error referencing mimeType.
}
