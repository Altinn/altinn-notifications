meta {
  name: Happy path - multiple attachments
  type: http
  seq: 2
}

post {
  url: {{host}}/notifications/api/v1/future/orders/email-with-attachments
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "{{senders_reference_guid}}",
    "requestedSendTime": "{{process.env.TESTDATA_REQUESTED_SEND_TIME}}",
    "recipient": {
      "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
      "emailSettings": {
        "subject": "(TEST) Email with multiple attachments",
        "body": "(TEST) Testmelding med flere vedlegg (Env.: {{Environment}} - Ref: {{random_idempotency_id}})",
        "contentType": "Plain",
        "sendingTimePolicy": "Anytime",
        "attachments": [
          {
            "filename": "document.pdf",
            "mimeType": "application/pdf",
            "sasUrl": "{{process.env.TESTDATA_ATTACHMENT_SAS_URL}}"
          },
          {
            "filename": "spreadsheet.xlsx",
            "mimeType": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            "sasUrl": "{{process.env.TESTDATA_ATTACHMENT_SAS_URL_2}}"
          }
        ]
      }
    }
  }
}

docs {
  Happy path: registers a notification order for an email with multiple attachments of different types.

  Required environment variables:
  - TESTDATA_MY_EMAIL: Recipient email address
  - TESTDATA_ATTACHMENT_SAS_URL: Valid SAS URL to a PDF blob
  - TESTDATA_ATTACHMENT_SAS_URL_2: Valid SAS URL to an XLSX blob
  - TESTDATA_REQUESTED_SEND_TIME: ISO 8601 UTC datetime

  Expected: 201 Created with order chain details in the response body.
}
