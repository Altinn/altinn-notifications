meta {
  name: reminder-sendtime-happy
  type: http
  seq: 2
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-reminder-{{senders_reference_guid}}",
    "recipient": {
      "recipientEmail": {
        "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
        "emailSettings": {
          "subject": "(REGRESSION) Reminder Test",
          "body": "(REGRESSION) Reminder test - {{random_idempotency_id}}",
          "contentType": "Plain",
          "sendingTimePolicy": "Anytime"
        }
      }
    },
    "reminders": [
      {
        "requestedSendTime": "{{reminderSendTime}}",
        "sendersReference": "regression-rem-2",
        "recipient": {
          "recipientEmail": {
            "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
            "emailSettings": {
              "subject": "(REGRESSION) Reminder",
              "body": "(REGRESSION) Reminder body",
              "contentType": "Plain",
              "sendingTimePolicy": "Anytime"
            }
          }
        }
      }
    ]
  }
}

script:pre-request {
  const date = new Date();
  date.setDate(date.getDate() + 7);
  bru.setVar("reminderSendTime", date.toISOString());
}

tests {
  test("should return 201 for valid reminder with requestedSendTime", function() {
    expect(res.status).to.equal(201);
  });
}
