meta {
  name: reminder-sendtime-no-tz
  type: http
  seq: 7
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-reminder-{{senders_reference_guid}}",
    "recipient": {
      "recipientEmail": {
        "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
        "emailSettings": {
          "subject": "(REGRESSION) Reminder Test",
          "body": "(REGRESSION) Reminder test - {{random_idempotency_id}}",
          "contentType": "Plain",
          "sendingTimePolicy": "Anytime"
        }
      }
    },
    "reminders": [
      {
        "requestedSendTime": "2099-01-01T00:00:00",
        "sendersReference": "regression-rem-7",
        "recipient": {
          "recipientEmail": {
            "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
            "emailSettings": {
              "subject": "(REGRESSION) Reminder",
              "body": "(REGRESSION) Reminder body",
              "contentType": "Plain",
              "sendingTimePolicy": "Anytime"
            }
          }
        }
      }
    ]
  }
}

tests {
  test("should return 400 when requestedSendTime has no timezone", function() {
    expect(res.status).to.equal(400);
  });

  test("response should mention time zone requirement", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    expect(body).to.include("time zone");
  });
}
