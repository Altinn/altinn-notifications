meta {
  name: reminder-both-delay-and-sendtime
  type: http
  seq: 3
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-reminder-{{senders_reference_guid}}",
    "recipient": {
      "recipientEmail": {
        "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
        "emailSettings": {
          "subject": "(REGRESSION) Reminder Test",
          "body": "(REGRESSION) Reminder test - {{random_idempotency_id}}",
          "contentType": "Plain",
          "sendingTimePolicy": "Anytime"
        }
      }
    },
    "reminders": [
      {
        "delayDays": 3,
        "requestedSendTime": "2099-01-01T00:00:00Z",
        "sendersReference": "regression-rem-3",
        "recipient": {
          "recipientEmail": {
            "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
            "emailSettings": {
              "subject": "(REGRESSION) Reminder",
              "body": "(REGRESSION) Reminder body",
              "contentType": "Plain",
              "sendingTimePolicy": "Anytime"
            }
          }
        }
      }
    ]
  }
}

tests {
  test("should return 400 when both delayDays and requestedSendTime are provided", function() {
    expect(res.status).to.equal(400);
  });

  test("response should mention DelayDays or RequestedSendTime conflict", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    const mentionsConflict = body.includes("delaydays") || body.includes("requestedsendtime") || body.includes("not both");
    expect(mentionsConflict).to.be.true;
  });
}
