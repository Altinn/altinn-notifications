meta {
  name: reminder-condition-endpoint
  type: http
  seq: 8
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-reminder-{{senders_reference_guid}}",
    "recipient": {
      "recipientEmail": {
        "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
        "emailSettings": {
          "subject": "(REGRESSION) Reminder Test",
          "body": "(REGRESSION) Reminder test - {{random_idempotency_id}}",
          "contentType": "Plain",
          "sendingTimePolicy": "Anytime"
        }
      }
    },
    "reminders": [
      {
        "delayDays": 3,
        "conditionEndpoint": "{{process.env.TESTDATA_URL_CONDITION_TRUE}}",
        "sendersReference": "regression-rem-8",
        "recipient": {
          "recipientEmail": {
            "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
            "emailSettings": {
              "subject": "(REGRESSION) Reminder",
              "body": "(REGRESSION) Reminder body",
              "contentType": "Plain",
              "sendingTimePolicy": "Anytime"
            }
          }
        }
      }
    ]
  }
}

tests {
  test("should return 201 for reminder with conditionEndpoint", function() {
    expect(res.status).to.equal(201);
  });
}
