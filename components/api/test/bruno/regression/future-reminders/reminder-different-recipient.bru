meta {
  name: reminder-different-recipient
  type: http
  seq: 9
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-reminder-{{senders_reference_guid}}",
    "recipient": {
      "recipientEmail": {
        "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
        "emailSettings": {
          "subject": "(REGRESSION) Reminder Test",
          "body": "(REGRESSION) Reminder test - {{random_idempotency_id}}",
          "contentType": "Plain",
          "sendingTimePolicy": "Anytime"
        }
      }
    },
    "reminders": [
      {
        "delayDays": 5,
        "sendersReference": "regression-rem-9",
        "recipient": {
          "recipientPerson": {
            "nationalIdentityNumber": "{{process.env.TESTDATA_TENOR_SET_1_PERSON}}",
            "resourceId": "urn:altinn:resource:te_svc123",
            "channelSchema": "Email",
            "emailSettings": {
              "subject": "(REGRESSION) Reminder to person",
              "body": "(REGRESSION) Reminder to person",
              "sendingTimePolicy": "Anytime"
            }
          }
        }
      }
    ]
  }
}

tests {
  test("should return 201 for reminder with different recipient type", function() {
    expect(res.status).to.equal(201);
  });
}
