meta {
  name: reminder-delaydays-zero
  type: http
  seq: 5
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-reminder-{{senders_reference_guid}}",
    "recipient": {
      "recipientEmail": {
        "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
        "emailSettings": {
          "subject": "(REGRESSION) Reminder Test",
          "body": "(REGRESSION) Reminder test - {{random_idempotency_id}}",
          "contentType": "Plain",
          "sendingTimePolicy": "Anytime"
        }
      }
    },
    "reminders": [
      {
        "delayDays": 0,
        "sendersReference": "regression-rem-5",
        "recipient": {
          "recipientEmail": {
            "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
            "emailSettings": {
              "subject": "(REGRESSION) Reminder",
              "body": "(REGRESSION) Reminder body",
              "contentType": "Plain",
              "sendingTimePolicy": "Anytime"
            }
          }
        }
      }
    ]
  }
}

tests {
  test("should return 400 when delayDays is zero", function() {
    expect(res.status).to.equal(400);
  });

  test("response should mention minimum value requirement", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    expect(body).to.include("greater than or equal to 1");
  });
}
