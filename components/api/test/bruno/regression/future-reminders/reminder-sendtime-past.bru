meta {
  name: reminder-sendtime-past
  type: http
  seq: 6
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-reminder-{{senders_reference_guid}}",
    "recipient": {
      "recipientEmail": {
        "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
        "emailSettings": {
          "subject": "(REGRESSION) Reminder Test",
          "body": "(REGRESSION) Reminder test - {{random_idempotency_id}}",
          "contentType": "Plain",
          "sendingTimePolicy": "Anytime"
        }
      }
    },
    "reminders": [
      {
        "requestedSendTime": "2020-01-01T00:00:00Z",
        "sendersReference": "regression-rem-6",
        "recipient": {
          "recipientEmail": {
            "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
            "emailSettings": {
              "subject": "(REGRESSION) Reminder",
              "body": "(REGRESSION) Reminder body",
              "contentType": "Plain",
              "sendingTimePolicy": "Anytime"
            }
          }
        }
      }
    ]
  }
}

tests {
  test("should return 400 when requestedSendTime is in the past", function() {
    expect(res.status).to.equal(400);
  });

  test("response should mention time constraint", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    const mentionsTime = body.includes("greater than or equal to") || body.includes("current utc");
    expect(mentionsTime).to.be.true;
  });
}
