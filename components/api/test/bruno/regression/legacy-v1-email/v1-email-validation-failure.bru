meta {
  name: v1-email-validation-failure
  type: http
  seq: 2
}

post {
  url: {{host}}/notifications/api/v1/orders
  body: json
  auth: inherit
}

body:json {
  {
    "resourceId": "app_ttd_regression-test",
    "notificationChannel": "Email",
    "emailTemplate": {
      "subject": "",
      "body": "test",
      "contentType": "Plain"
    },
    "recipients": [
      {
        "emailAddress": "test@example.com"
      }
    ]
  }
}

tests {
  test("returns 400 Bad Request", function() {
    expect(res.status).to.equal(400);
  });

  test("mentions subject", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    expect(body).to.include("subject");
  });
}
