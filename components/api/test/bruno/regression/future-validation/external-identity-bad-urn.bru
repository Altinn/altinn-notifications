meta {
  name: external-identity-bad-urn
  type: http
  seq: 13
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "recipient": {
      "recipientExternalIdentity": {
        "resourceId": "urn:altinn:resource:te_svc123",
        "externalIdentity": "not-a-urn",
        "channelSchema": "Email",
        "emailSettings": {
          "subject": "test",
          "body": "test",
          "sendingTimePolicy": "Anytime"
        }
      }
    }
  }
}

tests {
  test("returns 400", function() {
    expect(res.status).to.equal(400);
  });

  test("error mentions URN or external identity", function() {
    const body = JSON.stringify(res.body);
    const hasUrn = body.toUpperCase().includes("URN");
    const hasExternal = body.toLowerCase().includes("external identity");
    expect(hasUrn || hasExternal).to.be.true;
  });
}
