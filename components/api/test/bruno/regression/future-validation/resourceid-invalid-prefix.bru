meta {
  name: resourceid-invalid-prefix
  type: http
  seq: 9
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "recipient": {
      "recipientPerson": {
        "nationalIdentityNumber": "{{process.env.TESTDATA_TENOR_SET_1_PERSON}}",
        "resourceId": "invalid:resource:test",
        "channelSchema": "Email",
        "emailSettings": {
          "subject": "(REGRESSION) Validation",
          "body": "(REGRESSION) Validation test",
          "sendingTimePolicy": "Anytime"
        }
      }
    }
  }
}

tests {
  test("returns 400", function() {
    expect(res.status).to.equal(400);
  });

  test("error mentions ResourceId or valid syntax", function() {
    const body = JSON.stringify(res.body);
    const hasResourceId = body.includes("ResourceId") || body.includes("resourceId");
    const hasValidSyntax = body.toLowerCase().includes("valid syntax");
    expect(hasResourceId || hasValidSyntax).to.be.true;
  });
}
