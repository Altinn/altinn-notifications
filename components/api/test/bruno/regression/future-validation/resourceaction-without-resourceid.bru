meta {
  name: resourceaction-without-resourceid
  type: http
  seq: 10
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "recipient": {
      "recipientPerson": {
        "nationalIdentityNumber": "{{process.env.TESTDATA_TENOR_SET_1_PERSON}}",
        "resourceAction": "read",
        "channelSchema": "Email",
        "emailSettings": {
          "subject": "(REGRESSION) Validation",
          "body": "(REGRESSION) Validation test",
          "sendingTimePolicy": "Anytime"
        }
      }
    }
  }
}

tests {
  test("returns 400", function() {
    expect(res.status).to.equal(400);
  });

  test("error mentions ResourceAction cannot be specified without", function() {
    const body = JSON.stringify(res.body);
    expect(body).to.include("ResourceAction cannot be specified without");
  });
}
