meta {
  name: phone-no-country-code
  type: http
  seq: 5
}

post {
  url: {{host}}/notifications/api/v1/future/orders/instant/sms
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-validation-phone-no-cc",
    "recipientSms": {
      "phoneNumber": "99999999",
      "timeToLiveInSeconds": 120,
      "smsSettings": {
        "sender": "Regression",
        "body": "(REGRESSION) Phone no country code test"
      }
    }
  }
}

tests {
  test("returns 400", function() {
    expect(res.status).to.equal(400);
  });

  test("error mentions mobile number", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    expect(body).to.include("mobile number");
  });
}
