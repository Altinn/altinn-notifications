meta {
  name: external-identity-empty
  type: http
  seq: 14
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "recipient": {
      "recipientExternalIdentity": {
        "resourceId": "urn:altinn:resource:te_svc123",
        "externalIdentity": "",
        "channelSchema": "Email",
        "emailSettings": {
          "subject": "test",
          "body": "test",
          "sendingTimePolicy": "Anytime"
        }
      }
    }
  }
}

tests {
  test("returns 400", function() {
    expect(res.status).to.equal(400);
  });

  test("error mentions ExternalIdentity or empty", function() {
    const body = JSON.stringify(res.body);
    const hasExternalIdentity = body.includes("ExternalIdentity") || body.includes("externalIdentity");
    const hasEmpty = body.toLowerCase().includes("empty");
    expect(hasExternalIdentity || hasEmpty).to.be.true;
  });
}
