meta {
  name: status-feed-with-pagesize
  type: http
  seq: 2
}

get {
  url: {{host}}/notifications/api/v1/future/shipment/feed?seq=0&pageSize=5
  body: none
  auth: inherit
}

params:query {
  seq: 0
  pageSize: 5
}

tests {
  test("returns 200", function() {
    expect(res.status).to.equal(200);
  });

  test("response is array", function() {
    expect(res.body).to.be.an("array");
  });

  test("respects pageSize limit", function() {
    expect(res.body.length).to.be.at.most(5);
  });
}
