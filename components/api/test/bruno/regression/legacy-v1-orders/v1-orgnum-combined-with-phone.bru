meta {
  name: v1-orgnum-combined-with-phone
  type: http
  seq: 17
}

post {
  url: {{host}}/notifications/api/v1/orders
  body: json
  auth: inherit
}

body:json {
  {
    "resourceId": "app_ttd_regression-test",
    "notificationChannel": "Sms",
    "smsTemplate": {
      "body": "test"
    },
    "recipients": [
      {
        "organizationNumber": "123456789",
        "mobileNumber": "+4799999999"
      }
    ]
  }
}

tests {
  test("returns 400 Bad Request", function() {
    expect(res.status).to.equal(400);
  });

  test("error mentions cannot be combined", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    expect(body).to.include("cannot be combined");
  });
}
