meta {
  name: v1-cancel-nonexistent-order
  type: http
  seq: 11
}

put {
  url: {{host}}/notifications/api/v1/orders/:notificationId/cancel
  body: none
  auth: inherit
}

params:path {
  notificationId: 00000000-0000-0000-0000-000000000000
}

tests {
