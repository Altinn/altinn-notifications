meta {
  name: v1-sms-missing-template
  type: http
  seq: 15
}

post {
  url: {{host}}/notifications/api/v1/orders
  body: json
  auth: inherit
}

body:json {
  {
    "resourceId": "app_ttd_regression-test",
    "notificationChannel": "Sms",
    "recipients": [
      {
        "mobileNumber": "+4799999999"
      }
    ]
  }
}

tests {
  test("returns 400 Bad Request", function() {
    expect(res.status).to.equal(400);
  });

  test("error mentions sms template", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    expect(body).to.include("sms template");
  });
}
