meta {
  name: condition-false-skips
  type: http
  seq: 2
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-cond-false-{{senders_reference_guid}}",
    "conditionEndpoint": "{{process.env.TESTDATA_URL_CONDITION_FALSE}}",
    "recipient": {
      "recipientEmail": {
        "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
        "emailSettings": {
          "subject": "(REGRESSION) Condition False",
          "body": "(REGRESSION) Should be skipped - condition returns false",
          "contentType": "Plain",
          "sendingTimePolicy": "Anytime"
        }
      }
    }
  }
}

tests {
  test("returns 201 Created", function() {
    expect(res.status).to.equal(201);
  });
}
