meta {
  name: v1-sms-ep-no-recipients
  type: http
  seq: 5
}

post {
  url: {{host}}/notifications/api/v1/orders/sms
  body: json
  auth: inherit
}

body:json {
  {
    "resourceId": "app_ttd_regression-test",
    "body": "(REGRESSION) No recipients test",
    "recipients": []
  }
}

tests {
  test("returns 400 Bad Request", function() {
    expect(res.status).to.equal(400);
  });

  test("error mentions recipient", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    expect(body).to.include("recipient");
  });
}
