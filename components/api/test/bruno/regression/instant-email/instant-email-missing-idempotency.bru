meta {
  name: instant-email-missing-idempotency
  type: http
  seq: 3
}

post {
  url: {{host}}/notifications/api/v1/future/orders/instant/email
  body: json
  auth: inherit
}

body:json {
  {
    "sendersReference": "regression-email-{{senders_reference_guid}}",
    "recipientEmail": {
      "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
      "emailSettings": {
        "subject": "(REGRESSION) Instant Email Missing Idempotency",
        "body": "(REGRESSION) Missing idempotency test body",
        "contentType": "Plain",
        "senderEmailAddress": "noreply@altinn.no"
      }
    }
  }
}

tests {
  test("returns 400", function() {
    expect(res.status).to.equal(400);
  });

  test("error mentions idempotencyId", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    expect(body).to.include("idempotencyid");
  });
}
