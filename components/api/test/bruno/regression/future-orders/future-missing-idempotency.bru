meta {
  name: future-missing-idempotency
  type: http
  seq: 3
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "sendersReference": "regression-{{senders_reference_guid}}",
    "recipient": {
      "recipientEmail": {
        "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
        "emailSettings": {
          "subject": "(REGRESSION) Future Email",
          "body": "(REGRESSION) Test missing idempotency",
          "contentType": "Plain",
          "sendingTimePolicy": "Anytime"
        }
      }
    }
  }
}

tests {
  test("should return 400 Bad Request", function() {
    expect(res.status).to.equal(400);
  });

  test("error mentions idempotencyId", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    expect(body).to.include("idempotencyid");
  });
}
