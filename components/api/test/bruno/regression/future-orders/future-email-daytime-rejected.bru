meta {
  name: future-email-daytime-rejected
  type: http
  seq: 6
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-{{senders_reference_guid}}",
    "recipient": {
      "recipientEmail": {
        "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
        "emailSettings": {
          "subject": "(REGRESSION) Future Email Daytime",
          "body": "(REGRESSION) Test daytime rejected",
          "contentType": "Plain",
          "sendingTimePolicy": "Daytime"
        }
      }
    }
  }
}

tests {
  test("should return 400 Bad Request", function() {
    expect(res.status).to.equal(400);
  });

  test("error should mention email only supports anytime", function() {
    const body = res.getBody();
    const bodyString = JSON.stringify(body);
    expect(bodyString.toLowerCase()).to.include("email only supports send time anytime");
  });
}
