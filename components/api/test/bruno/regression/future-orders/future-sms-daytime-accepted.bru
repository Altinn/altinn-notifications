meta {
  name: future-sms-daytime-accepted
  type: http
  seq: 7
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-{{senders_reference_guid}}",
    "recipient": {
      "recipientPerson": {
        "nationalIdentityNumber": "{{process.env.TESTDATA_TENOR_SET_1_PERSON}}",
        "resourceId": "urn:altinn:resource:te_svc123",
        "channelSchema": "Sms",
        "smsSettings": {
          "sendingTimePolicy": "Daytime",
          "body": "(REGRESSION) Future SMS Daytime Test - {{random_idempotency_id}}"
        }
      }
    }
  }
}

tests {
  test("should return 201 Created", function() {
    expect(res.status).to.equal(201);
  });
}
