meta {
  name: future-email-happy-path
  type: http
  seq: 1
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-{{senders_reference_guid}}",
    "recipient": {
      "recipientEmail": {
        "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
        "emailSettings": {
          "subject": "(REGRESSION) Future Email",
          "body": "(REGRESSION) Test - {{random_idempotency_id}}",
          "contentType": "Plain",
          "sendingTimePolicy": "Anytime"
        }
      }
    }
  }
}

tests {
  test("should return 201 Created", function() {
    expect(res.status).to.equal(201);
  });

  test("response has shipmentId", function() {
    expect(res.body.notification).to.have.property("shipmentId");
  });
}
