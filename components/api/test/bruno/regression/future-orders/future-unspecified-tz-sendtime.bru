meta {
  name: future-unspecified-tz-sendtime
  type: http
  seq: 11
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-{{senders_reference_guid}}",
    "requestedSendTime": "2099-01-01T00:00:00",
    "recipient": {
      "recipientEmail": {
        "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
        "emailSettings": {
          "subject": "(REGRESSION) Future Email No TZ",
          "body": "(REGRESSION) Test unspecified timezone",
          "contentType": "Plain",
          "sendingTimePolicy": "Anytime"
        }
      }
    }
  }
}

tests {
  test("should return 400 Bad Request", function() {
    expect(res.status).to.equal(400);
  });

  test("error should mention time zone", function() {
    const body = res.getBody();
    const bodyString = JSON.stringify(body).toLowerCase();
    expect(bodyString).to.satisfy(function(s) {
      return s.includes("time zone") || s.includes("timezone");
    });
  });
}
