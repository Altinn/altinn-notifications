meta {
  name: v1-email-ep-missing-subject
  type: http
  seq: 2
}

post {
  url: {{host}}/notifications/api/v1/orders/email
  body: json
  auth: inherit
}

body:json {
  {
    "resourceId": "app_ttd_regression-test",
    "body": "(REGRESSION) Missing subject test",
    "contentType": "Plain",
    "recipients": [
      {
        "emailAddress": "test@example.com"
      }
    ]
  }
}

tests {
  test("returns 400 Bad Request", function() {
    expect(res.status).to.equal(400);
  });

  test("error mentions subject", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    expect(body).to.include("subject");
  });
}
