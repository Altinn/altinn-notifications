meta {
  name: v1-email-ep-nin-with-email
  type: http
  seq: 5
}

post {
  url: {{host}}/notifications/api/v1/orders/email
  body: json
  auth: inherit
}

body:json {
  {
    "resourceId": "app_ttd_regression-test",
    "subject": "(REGRESSION) NIN combined with email",
    "body": "(REGRESSION) Test body",
    "contentType": "Plain",
    "recipients": [
      {
        "emailAddress": "test@example.com",
        "nationalIdentityNumber": "12345678901"
      }
    ]
  }
}

tests {
  test("returns 400 Bad Request", function() {
    expect(res.status).to.equal(400);
  });

  test("error mentions combination not allowed", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    expect(body).to.include("combin");
  });
}
