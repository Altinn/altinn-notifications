meta {
  name: instant-sms-missing-idempotency
  type: http
  seq: 3
}

post {
  url: {{host}}/notifications/api/v1/future/orders/instant/sms
  body: json
  auth: inherit
}

body:json {
  {
    "sendersReference": "regression-sms-no-idempotency",
    "recipientSms": {
      "phoneNumber": "{{process.env.TESTDATA_MY_PHONE}}",
      "timeToLiveInSeconds": 120,
      "smsSettings": {
        "sender": "Regression",
        "body": "(REGRESSION) Missing idempotency test"
      }
    }
  }
}

tests {
  test("should return 400 Bad Request", function() {
    expect(res.status).to.equal(400);
  });

  test("error mentions idempotencyId", function() {
    const body = JSON.stringify(res.body).toLowerCase();
    expect(body).to.include("idempotencyid");
  });
}
