meta {
  name: recipient-external-username
  type: http
  seq: 6
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-recip-user-{{senders_reference_guid}}",
    "recipient": {
      "recipientExternalIdentity": {
        "resourceId": "urn:altinn:resource:te_svc123",
        "externalIdentity": "{{process.env.TESTDATA_EXTERNAL_IDENTITY_USERNAME}}",
        "channelSchema": "Email",
        "emailSettings": {
          "subject": "(REGRESSION) External Username",
          "body": "(REGRESSION) External username test",
          "sendingTimePolicy": "Anytime"
        }
      }
    }
  }
}

tests {
  test("returns 201 or 422 (missing contact info in mock)", function() {
    expect([201, 422]).to.include(res.status);
  });

  test("response matches the contract for its status", function() {
    if (res.status === 201) {
      expect(res.body.notification).to.have.property("shipmentId");
    } else {
      // AltinnProblemDetails for Problems.MissingContactInformation
      expect(JSON.stringify(res.body)).to.include("NOT-00001");
    }
  });
}
