meta {
  name: recipient-sms-direct
  type: http
  seq: 2
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-recip-sms-{{senders_reference_guid}}",
    "recipient": {
      "recipientSms": {
        "phoneNumber": "{{process.env.TESTDATA_MY_PHONE}}",
        "smsSettings": {
          "sendingTimePolicy": "Anytime",
          "body": "(REGRESSION) Direct SMS recipient test"
        }
      }
    }
  }
}

tests {
  test("returns 201 Created", function() {
    expect(res.status).to.equal(201);
  });
}
