meta {
  name: recipient-external-legacy-si
  type: http
  seq: 7
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-recip-si-{{senders_reference_guid}}",
    "recipient": {
      "recipientExternalIdentity": {
        "resourceId": "urn:altinn:resource:te_svc123",
        "externalIdentity": "{{process.env.TESTDATA_EXTERNAL_IDENTITY_LEGACY_SI}}",
        "channelSchema": "Email",
        "emailSettings": {
          "subject": "(REGRESSION) External Legacy SI",
          "body": "(REGRESSION) External legacy self-identified test",
          "sendingTimePolicy": "Anytime"
        }
      }
    }
  }
}

tests {
  test("returns 201 or 422 (missing contact info in mock)", function() {
    expect([201, 422]).to.include(res.status);
  });
}
