meta {
  name: recipient-external-idporten
  type: http
  seq: 5
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "regression-recip-idp-{{senders_reference_guid}}",
    "recipient": {
      "recipientExternalIdentity": {
        "resourceId": "urn:altinn:resource:te_svc123",
        "externalIdentity": "urn:altinn:person:idporten-email:test@example.com",
        "channelSchema": "Email",
        "emailSettings": {
          "subject": "(REGRESSION) External IDporten",
          "body": "(REGRESSION) External IDporten test",
          "sendingTimePolicy": "Anytime"
        }
      }
    }
  }
}

tests {
  test("returns 201 or 422 (missing contact info in mock)", function() {
    expect([201, 422]).to.include(res.status);
  });
}
