meta {
  name: 01-create-order
  type: http
  seq: 1
}

post {
  url: {{host}}/notifications/api/v1/future/orders
  body: json
  auth: inherit
}

body:json {
  {
    "idempotencyId": "{{random_idempotency_id}}",
    "sendersReference": "e2e-feed-{{senders_reference_guid}}",
    "recipient": {
      "recipientEmail": {
        "emailAddress": "{{process.env.TESTDATA_MY_EMAIL}}",
        "emailSettings": {
          "subject": "(E2E) Status Feed Flow",
          "body": "(E2E) Status feed flow test - {{random_idempotency_id}}",
          "contentType": "Plain",
          "sendingTimePolicy": "Anytime"
        }
      }
    }
  }
}

script:post-response {
  if (res.status === 201 && res.body && res.body.notification && res.body.notification.shipmentId) {
    bru.setVar("e2eFeedShipmentId", res.body.notification.shipmentId);
  }
}

tests {
  test("returns 201 Created", function() {
    expect(res.status).to.equal(201);
  });

  test("response has shipmentId", function() {
    expect(res.body.notification).to.have.property("shipmentId");
  });
}
