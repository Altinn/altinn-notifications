meta {
  name: 02-wait-and-check-failed
  type: http
  seq: 2
}

get {
  url: {{host}}/notifications/api/v1/future/shipment/:notificationId
  body: none
  auth: inherit
}

params:path {
  notificationId: {{e2ePermFailShipmentId}}
}

script:pre-request {
  // Wait for async processing: trigger scheduler fires every 5s, then email-service processes
  await new Promise(resolve => setTimeout(resolve, 15000));
}

tests {
  test("returns 200", function() {
    expect(res.status).to.equal(200);
  });

  test("email recipient ended in failed state", function() {
    // The mock email client returns a permanent failure for permanent-fail@test.com
    expect(res.body).to.be.an("object");
    expect(res.body.recipients).to.be.an("array").that.is.not.empty;
    const statuses = res.body.recipients.map(r => r.status);
    expect(statuses, `recipient statuses: ${statuses.join(", ")}`).to.include("Email_Failed");
  });
}
