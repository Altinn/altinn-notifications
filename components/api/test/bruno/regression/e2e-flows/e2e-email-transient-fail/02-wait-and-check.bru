meta {
  name: 02-wait-and-check
  type: http
  seq: 2
}

get {
  url: {{host}}/notifications/api/v1/future/shipment/:notificationId
  body: none
  auth: inherit
}

params:path {
  notificationId: {{e2eTransientShipmentId}}
}

script:pre-request {
  // Transient fail: first SendEmail call fails, status consumer publishes error.
  // The notification should end up with a Failed_TransientError status.
  await new Promise(resolve => setTimeout(resolve, 15000));
}

tests {
  test("returns 200", function() {
    expect(res.status).to.equal(200);
  });

  test("shipment has been processed (with transient error)", function() {
    expect(res.body).to.be.an("object");
  });
}
