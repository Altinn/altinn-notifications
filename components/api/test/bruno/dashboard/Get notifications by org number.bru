meta {
  name: Get notifications by org number
  type: http
  seq: 2
}

get {
  url: {{host}}/notifications/api/v1/future/dashboard/recipients/notifications/orgnumber
  body: none
  auth: inherit
}

params:query {
  ~from: {{dateFrom}}
  ~to: {{dateTo}}
}

headers {
  OrganizationNumber: {{orgNumber}}
}

vars:pre-request {
  orgNumber: 910493353
}

script:pre-request {
  const from = bru.getEnvVar("dateFrom");
  const to = bru.getEnvVar("dateTo");

  const sevenDaysAgo = new Date();
  sevenDaysAgo.setDate(sevenDaysAgo.getDate() - 7);

  bru.setVar("dateFrom", from || sevenDaysAgo.toISOString());
  bru.setVar("dateTo", to || new Date().toISOString());
}

settings {
  encodeUrl: true
  timeout: 0
}
