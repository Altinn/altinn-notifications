meta {
  name: Get Daily Sms metrics
  type: http
  seq: 1
}

post {
  url: {{host}}/notifications/api/v1/metrics/sms
  body: none
  auth: inherit
}

headers {
  X-API-Key: {{process.env.METRICS_API_KEY}}
  Ocp-Apim-Subscription-Key: {{process.env.METRICS_SUBSCRIPTION_KEY}}
}

settings {
  encodeUrl: true
  timeout: 0
}
